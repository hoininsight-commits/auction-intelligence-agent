APP_NAME=Auction Intelligence Agent
APP_ENV=local
DEBUG=true

DATABASE_URL=postgresql+psycopg://auction:auction@postgres:5432/auction_db
TEST_DATABASE_URL=postgresql+psycopg://auction:auction@postgres:5432/auction_test_db

REDIS_URL=redis://redis:6379/0

SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 공공데이터포털(data.go.kr)에서 "한국자산관리공사_온비드 캠코공매물건 조회서비스"
# (https://www.data.go.kr/data/15000851/openapi.do) 활용신청 후 발급받은 서비스키(Encoding)를 입력
ONBID_API_KEY=
# 공공데이터포털(data.go.kr)에서 "국토교통부_아파트 매매 실거래상세 자료"
# (https://www.data.go.kr/data/15126468/openapi.do) 활용신청 후 발급받은 서비스키(Decoding)를 입력
MOLIT_API_KEY=
PUBLIC_DATA_API_KEY=
KAKAO_MAP_API_KEY=
NAVER_MAP_API_KEY=

ENABLE_MOCK_CONNECTORS=true
